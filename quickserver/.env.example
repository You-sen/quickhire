# Backend Environment Variables
# Copy this file to .env and update the values

# Server Port
PORT=3001

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/quickhire
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/quickhire?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/quickhire

# Node Environment (development, production, test)
NODE_ENV=development

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000
